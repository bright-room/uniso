{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist-web",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "paths": {
      "@uniso/shared": ["../../packages/shared/src"],
      "@uniso/shared/*": ["../../packages/shared/src/*"],
      "@uniso/ui": ["../../packages/ui/src"],
      "@uniso/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src/renderer/src/**/*.ts", "src/renderer/src/**/*.tsx"]
}
