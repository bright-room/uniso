{
  "name": "uniso",
  "private": true,
  "engines": {
    "node": ">=24.14.1",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "dev": "pnpm --filter @uniso/desktop dev",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter @uniso/shared test:watch",
    "package": "pnpm --filter @uniso/desktop package",
    "package:mac": "pnpm --filter @uniso/desktop package:mac",
    "package:win": "pnpm --filter @uniso/desktop package:win",
    "storybook": "pnpm --filter @uniso/ui storybook",
    "test:e2e": "pnpm --filter @uniso/desktop build && pnpm --filter @uniso/desktop test:e2e",
    "security:audit": "pnpm audit --prod",
    "security:glassworm": "anti-trojan-source --files='{apps/*/src,packages/*/src,.github}/**/*.{ts,tsx,js,json,css,html,yml,yaml}'",
    "security:check": "pnpm security:audit; pnpm security:glassworm"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ],
    "patchedDependencies": {
      "anti-trojan-source@1.8.1": "patches/anti-trojan-source@1.8.1.patch"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "anti-trojan-source": "^1.8.1"
  }
}
